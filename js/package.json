{
  "name": "uuid-kit",
  "version": "2.0.0",
  "description": "Generate UUID values (v4, v7) with formatting, prefixes, suffixes, and flexible output shapes.",
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "test": "node --input-type=module -e \"import('./index.js').then(() => console.log('ok'))\""
  },
  "dependencies": {
    "uuid": "^10.0.0"
  },
  "keywords": [
    "uuid",
    "uuidv4",
    "uuidv7",
    "uuid-generator",
    "uuid-format",
    "uuid-transform",
    "uuid-output",
    "uuid-tools",
    "uuid-utility"
  ],
  "author": "Troy Tessalone",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/troytessalone/uuid-kit.git"
  },
  "bugs": {
    "url": "https://github.com/troytessalone/uuid-kit/issues"
  },
  "homepage": "https://github.com/troytessalone/uuid-kit#readme"
}
